NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Test-only fixture mode. Do not enable for production deployments.
GATE_FIXTURE_MODE=0

# Forces __Host-prefixed, Secure session cookies outside NODE_ENV=production
# (e.g. a staging environment served over HTTPS that isn't flagged
# "production"). NODE_ENV=production already forces this; this is only an
# escape hatch for non-production HTTPS environments. Leave unset for local
# plain-HTTP development.
COOKIE_SECURE=0
