  "scenarios": {
    "K9-T1": {
      "title": "First-time bootstrap",
      "chain": [
        "POST /api/v1/auth/otp/verify",
        "GET /api/v1/me/context",
        "POST /api/v1/pet-life/households",
        "POST /api/v1/pet-life/households/{household_id}/pets",
        "POST /api/v1/pet-life/households/{household_id}/addresses",
        "GET /api/v1/me/context"
      ],
      "assertions": [
        "context starts with null default_household_id",
        "context ends with deterministic default_household_id",
        "onboarding requirements become complete"
      ]
    },
    "K9-T2": {
      "title": "Returning user",
      "chain": [
        "POST /api/v1/auth/otp/verify",
        "GET /api/v1/me/context",
        "GET /api/v1/pet-life/households/{household_id}/pets"
      ],
      "assertions": [
        "pet switcher reconstructs household and active pets without client-stored UUIDs"
      ]
    },
    "K9-T3": {
      "title": "Commerce/payment",
      "chain": [
        "GET /api/v1/catalog/offers/{offer_id}",
        "POST /api/v1/checkout/orders",
        "POST /api/v1/orders/{order_id}/payments/zarinpal",
        "GET /api/v1/payments/zarinpal/callback",
        "GET /api/v1/orders/{order_id}",
        "POST /api/v1/operator/order-lines/{line_id}/confirm-sourced"
      ],
      "assertions": [
        "IRR price snapshot is server-owned",
        "payment verification precedes sourcing",
        "one sourcing job is created"
      ]
    },
    "K9-T4": {
      "title": "Order pet plan",
      "chain": [
        "PUT /api/v1/orders/{order_id}/pet-plan",
        "GET /api/v1/orders/{order_id}",
        "POST /api/v1/operator/orders/{order_id}/deliver",
        "GET /api/v1/pet-life/inventory/{unit_id}"
      ],
      "assertions": [
        "planning creates no estimate",
        "delivery creates unopened inventory",
        "planned pets become unknown-share assignments"
      ]
    },
    "K9-T5": {
      "title": "Opening with known facts",
      "chain": [
        "PUT /api/v1/pet-life/inventory/{unit_id}/assignments",
        "POST /api/v1/pet-life/inventory/{unit_id}/open",
        "POST /api/v1/pet-life/inventory/{unit_id}/estimate/correct",
        "GET /api/v1/pet-life/inventory/{unit_id}",
        "GET /api/v1/pet-life/pets/{pet_id}/today"
      ],
      "assertions": [
        "exact grams are preserved",
        "semantic level input stores approved low/high bounds without exact grams",
        "known facts justify a pet range"
      ]
    },
    "K9-T6": {
      "title": "Unknown shares",
      "chain": [
        "PUT /api/v1/pet-life/inventory/{unit_id}/assignments",
        "POST /api/v1/pet-life/inventory/{unit_id}/open",
        "GET /api/v1/pet-life/pets/{pet_id}/today"
      ],
      "assertions": [
        "household estimate only",
        "no pet-level remaining days"
      ]
    },
    "K9-T7": {
      "title": "External purchase",
      "chain": [
        "POST /api/v1/pet-life/households/{household_id}/inventory/external",
        "PUT /api/v1/pet-life/inventory/{unit_id}/assignments",
        "POST /api/v1/pet-life/inventory/{unit_id}/open",
        "POST /api/v1/pet-life/inventory/{unit_id}/exhaust"
      ],
      "assertions": [
        "external units follow the same inventory lifecycle"
      ]
    },
    "K9-T8": {
      "title": "Reorder snooze",
      "chain": [
        "POST /api/v1/pet-life/inventory/{unit_id}/reorder-assessment",
        "PUT /api/v1/pet-life/inventory/{unit_id}/reorder-snooze",
        "GET /api/v1/pet-life/pets/{pet_id}/today"
      ],
      "assertions": [
        "snooze maximum is 72 hours",
        "Today suppresses reorder attention",
        "early return occurs only when low-day baseline worsens by at least 2 days and crosses the reorder threshold"
      ]
    },
    "K9-T9": {
      "title": "Availability",
      "chain": [
        "POST /api/v1/catalog/offers/{offer_id}/availability-subscriptions",
        "PUT /api/v1/operator/offers/{offer_id}/capacity",
        "GET /api/v1/pet-life/notifications",
        "GET /api/v1/me/availability-subscriptions"
      ],
      "assertions": [
        "order_created is false",
        "no order, payment, sourcing or inventory is created",
        "availability notification is max once per activation cycle"
      ]
    },
    "K9-T10": {
      "title": "Delayed order",
      "chain": [
        "POST /api/v1/operator/orders/{order_id}/fulfillment",
        "GET /api/v1/orders/{order_id}/journey",
        "POST /api/v1/orders/{order_id}/delay-acknowledgements"
      ],
      "assertions": [
        "acknowledgement persists visible delay version",
        "no compensation/cancellation/waiver implication"
      ]
    },
    "K9-T11": {
      "title": "Journey/Garden",
      "chain": [
        "GET /api/v1/pet-life/pets/{pet_id}/journey-offers",
        "GET /api/v1/pet-life/journey-definitions/{definition_id}",
        "POST /api/v1/pet-life/pets/{pet_id}/journeys",
        "POST /api/v1/pet-life/journeys/{journey_id}/check-ins",
        "GET /api/v1/pet-life/pets/{pet_id}/diary/{entry_id}",
        "PUT /api/v1/pet-life/garden/{reward_id}/placement",
        "DELETE /api/v1/pet-life/garden/{reward_id}/placement",
        "PUT /api/v1/pet-life/garden/{reward_id}/placement"
      ],
      "assertions": [
        "completion creates one diary memory and one Garden reward",
        "storage preserves linked memory"
      ]
    }
  },
